{
  "name": "fe-trading-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ui:headed": "PW_HEADED=1 playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check --config ./.prettier.config.ts",
    "format:write": "prettier . --write --config ./.prettier.config.ts",
    "generate:api-types": "openapi-typescript ./src/shared/api/openapi/orderbook.openapi.yaml -o ./src/shared/api/openapi/schema.ts",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.90.21",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "i18next": "^25.8.16",
    "i18next-browser-languagedetector": "^8.2.1",
    "openapi-fetch": "^0.17.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.6",
    "react-router-dom": "^7.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.3",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write --config ./.prettier.config.ts"
    ],
    "*.{js,json,md,css,html,yml,yaml}": [
      "prettier --write --config ./.prettier.config.ts"
    ]
  }
}
